# GPU Model Autoscaler - Environment Variables
# Copy to .env and fill in your values

# Model configuration
MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3
GPU_MODE=stub

# Cloud provider: stub | runpod | lambda
CLOUD_PROVIDER=stub

# RunPod (required if CLOUD_PROVIDER=runpod)
RUNPOD_API_KEY=
RUNPOD_GPU_TYPE=NVIDIA RTX A4000

# Lambda Labs (required if CLOUD_PROVIDER=lambda)
LAMBDA_API_KEY=
LAMBDA_REGION=us-east-1
LAMBDA_GPU_TYPE=gpu_1x_a10

# Autoscaling
MIN_WORKERS=1
MAX_WORKERS=8
SCALE_UP_THRESHOLD=3.0
SCALE_DOWN_THRESHOLD=0.3
COOLDOWN_SCALE_UP=60s
COOLDOWN_SCALE_DOWN=120s

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin